rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products can be read by anyone
    match /products/{productId} {
      allow read: if true;
      // Only authenticated users can write (admin)
      allow create, update, delete: if request.auth != null;
    }

    // Categories can be read by anyone
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Orders - created only via server-side Admin SDK (API route).
    // Direct client writes are blocked to prevent bot/flooding attacks.
    match /orders/{orderId} {
      allow create: if false;
      allow read, update, delete: if request.auth != null;
    }
  }
}
